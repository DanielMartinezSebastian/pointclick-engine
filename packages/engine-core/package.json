{
  "name": "@pointclick/engine-core",
  "version": "0.1.0",
  "description": "Framework-agnostic core for Point & Click Game Engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./commands": {
      "import": "./dist/game/commands/index.js",
      "types": "./dist/game/commands/index.d.ts"
    },
    "./events": {
      "import": "./dist/game/events/index.js",
      "types": "./dist/game/events/index.d.ts"
    },
    "./ports": {
      "import": "./dist/ports/index.js",
      "types": "./dist/ports/index.d.ts"
    },
    "./types": {
      "import": "./dist/game/types/index.js",
      "types": "./dist/game/types/index.d.ts"
    },
    "./state": {
      "import": "./dist/game/state/index.js",
      "types": "./dist/game/state/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "game",
    "point-and-click",
    "2d",
    "engine"
  ],
  "author": "Daniel Martínez Sebastián",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielmartinezsebastian/2d-game-test.git",
    "directory": "packages/engine-core"
  },
  "bugs": {
    "url": "https://github.com/danielmartinezsebastian/2d-game-test/issues"
  },
  "homepage": "https://github.com/danielmartinezsebastian/2d-game-test#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
